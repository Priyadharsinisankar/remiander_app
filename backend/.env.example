PORT=3000
DATABASE_URL=postgres://postgres:admin@localhost:5432/reminder_app

# Telegram is required for bot messages and /api/telegram/test.
TELEGRAM_BOT_TOKEN=
REMINDER_POLL_SECONDS=30

# Google Calendar OAuth. Add this redirect URI in Google Cloud:
# http://localhost:3000/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata

JIRA_API_TOKEN=
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task
LINEAR_PERSONAL_API_KEY=
LINEAR_WEBHOOK_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_TEAM_ID=

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

MS_CLIENT_ID=
MS_TENANT_ID=
MS_CLIENT_SECRET=
